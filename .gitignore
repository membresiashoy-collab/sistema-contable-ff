# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.venv/
venv/
env/

# Streamlit
.streamlit/secrets.toml

# Entornos / secretos
.env
.env.local

# Bases de datos locales / sensibles
*.db
*.sqlite
*.sqlite3

# Carpeta data: se conserva la carpeta, no la base
data/*
