# Backups: se conservan las carpetas, no los backups reales
backups/*
!backups/.gitkeep
!backups/sqlite/
!backups/sqlite/.gitkeep
!backups/exportaciones/
!backups/exportaciones/.gitkeep

# Archivos temporales
*.tmp
*.log

# Sistema operativo
.DS_Store
Thumbs.db